From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ttossj1 <ttossj1@example.com>
Date: Mon, 4 May 2026 10:31:03 +0900
Subject: [PATCH] prep_ubuntu_system: skip ubuntu-toolchain-r PPA when g++-14
 already available

On Ubuntu 24.04 noble (and Linux Mint 22.x, which rebases on noble),
g++-14 already ships in the main pocket.  Unconditionally calling
add-apt-repository -y ppa:ubuntu-toolchain-r/test pulls launchpad.net,
whose IPv4 endpoint frequently times out from GitHub-hosted runners
and other restricted networks, breaking the install with:

    Cannot add PPA: ''Connection timed out, check your connection or
    try again later.''

Probe apt-cache for g++-14 first and only add the PPA if the package
isn't already reachable from the configured repositories.

Distro-Scope: linuxmint-22.3, ubuntu-24.04
Issue: tt-metal community-distro-matrix Burst 2.4

Co-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>
---
 install_dependencies.sh | 17 ++++++++++++++---
 1 file changed, 14 insertions(+), 3 deletions(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index 460efc5..1a807c8 100755
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -309,11 +309,22 @@ prep_ubuntu_system() {
         apt-get install -y --no-install-recommends kitware-archive-keyring
     fi
 
-    # Add GCC toolchain repository for specific g++ versions if needed
+    # Add GCC toolchain repository for specific g++ versions if needed.
+    #
+    # Upstream unconditionally adds ppa:ubuntu-toolchain-r/test on noble, but
+    # g++-14 already ships in noble's main pocket (and in Linux Mint 22.x,
+    # which rebases on noble).  The PPA add reaches launchpad.net, whose
+    # IPv4 endpoint frequently times out from GitHub-hosted runners and
+    # other restricted networks.  Skip the PPA add when the toolchain is
+    # already satisfiable from the configured repos.
     case "$UBUNTU_CODENAME" in
         "noble")
-            echo "[INFO] Adding toolchain repository for g++-14 on Ubuntu 24.04"
-            add-apt-repository -y ppa:ubuntu-toolchain-r/test
+            if apt-cache show g++-14 >/dev/null 2>&1; then
+                echo "[INFO] g++-14 already available without ubuntu-toolchain-r PPA on $UBUNTU_CODENAME"
+            else
+                echo "[INFO] Adding toolchain repository for g++-14 on Ubuntu 24.04"
+                add-apt-repository -y ppa:ubuntu-toolchain-r/test
+            fi
             ;;
     esac
 
