From 79f596811b56eaed229fd55aae267b09d7f00b4c Mon Sep 17 00:00:00 2001
From: Tetsuya Hayashi <tetsu.h@gmail.com>
Date: Mon, 1 Jun 2026 07:15:53 +0900
Subject: [PATCH] prep_ubuntu_system: skip apt.llvm.org and CMake installer on
 Ubuntu 26.04

Ubuntu 26.04 resolute already ships clang-17, clang-20, llvm-20-dev,
and cmake 4.2 in the distro repositories, so the third-party
apt.llvm.org repository and the direct Kitware CMake installer are not
useful there.

apt.llvm.org has not yet published a resolute pocket, so adding the
source forces apt-get update to fail with a 404 before the actual
package installation runs. Guard both setup steps and use the distro
toolchain on resolute.

Distro-Scope: ubuntu-26.04

Upstream-Status: Pending
---
 install_dependencies.sh | 36 ++++++++++++++++++++++++------------
 1 file changed, 24 insertions(+), 12 deletions(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index 54fa5e1..ad5f060 100755
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -270,18 +270,30 @@ prep_ubuntu_system() {
     apt-get update
     apt-get install -y --no-install-recommends ca-certificates gpg lsb-release wget software-properties-common gnupg jq
 
-    # Add LLVM repository for Clang 17
-    wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | gpg --dearmor -o /etc/apt/trusted.gpg.d/apt-llvm-org.gpg
-    echo "deb http://apt.llvm.org/$OS_CODENAME/ llvm-toolchain-$OS_CODENAME-17 main" | tee /etc/apt/sources.list.d/llvm-17.list
-    # Also v20
-    echo "deb http://apt.llvm.org/$OS_CODENAME/ llvm-toolchain-$OS_CODENAME-20 main" | tee /etc/apt/sources.list.d/llvm-20.list
-
-    # Install CMake 4.0.2 directly from GitHub releases (avoids Kitware apt repo instability)
-    local cmake_version="4.0.2"
-    local cmake_installer="/tmp/cmake-${cmake_version}-installer.sh"
-    wget -q "https://github.com/Kitware/CMake/releases/download/v${cmake_version}/cmake-${cmake_version}-linux-x86_64.sh" -O "$cmake_installer"
-    bash "$cmake_installer" --skip-license --prefix=/usr/local
-    rm -f "$cmake_installer"
+    # Ubuntu 26.04 (resolute) ships clang-17, clang-20, llvm-20-dev
+    # and cmake (>= 4.2) directly in main/universe, so the
+    # apt.llvm.org repository and direct CMake installer are not needed.
+    # Skipping them also avoids the apt-get update 404 that comes from
+    # apt.llvm.org not yet publishing a ``resolute`` pocket.
+    case "$OS_CODENAME" in
+        resolute)
+            echo "[INFO] Skipping apt.llvm.org and CMake installer on $OS_CODENAME (distro provides clang-17/20 and cmake >= 4.2)"
+            ;;
+        *)
+            # Add LLVM repository for Clang 17
+            wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | gpg --dearmor -o /etc/apt/trusted.gpg.d/apt-llvm-org.gpg
+            echo "deb http://apt.llvm.org/$OS_CODENAME/ llvm-toolchain-$OS_CODENAME-17 main" | tee /etc/apt/sources.list.d/llvm-17.list
+            # Also v20
+            echo "deb http://apt.llvm.org/$OS_CODENAME/ llvm-toolchain-$OS_CODENAME-20 main" | tee /etc/apt/sources.list.d/llvm-20.list
+
+            # Install CMake 4.0.2 directly from GitHub releases (avoids Kitware apt repo instability)
+            local cmake_version="4.0.2"
+            local cmake_installer="/tmp/cmake-${cmake_version}-installer.sh"
+            wget -q "https://github.com/Kitware/CMake/releases/download/v${cmake_version}/cmake-${cmake_version}-linux-x86_64.sh" -O "$cmake_installer"
+            bash "$cmake_installer" --skip-license --prefix=/usr/local
+            rm -f "$cmake_installer"
+            ;;
+    esac
 
     # Add GCC toolchain repository for specific g++ versions if needed
     case "$UBUNTU_CODENAME" in
-- 
2.43.0

