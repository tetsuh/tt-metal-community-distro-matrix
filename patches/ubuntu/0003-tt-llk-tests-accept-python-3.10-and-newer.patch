From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Tetsuya Hayashi <tetsu.h@gmail.com>
Date: Thu, 15 May 2026 08:32:00 +0900
Subject: [PATCH] tt-llk tests: accept Python 3.10+ and detect package
 manager in external env setup

The LLK test environment bootstrap currently hard-stops unless the host
interpreter string starts with `3.10`, then unconditionally uses
`sudo apt-get` for its system package install step. That blocks the
distro matrix runtime smoke on two axes:

1. community distros with newer default Python interpreters are rejected
   before the actual test dependencies and simulator tests get a chance
   to run;
2. Red Hat family distros reach the setup script but then fail because
   `apt-get` is not available there.

Relax the version gate to require Python 3.10 or newer, and detect the
package manager before installing the setup prerequisites. This lets the
matrix surface the real compatibility problems that remain beyond the
preflight checks.

Upstream-Status: Pending
Distro-Scope: ubuntu-26.04
---
 tt_metal/tt-llk/tests/setup_external_testing_env.sh | 68 ++++++++++++++++++++--
 1 file changed, 62 insertions(+), 6 deletions(-)

diff --git a/tt_metal/tt-llk/tests/setup_external_testing_env.sh b/tt_metal/tt-llk/tests/setup_external_testing_env.sh
index 4ea7e2b..fa532d8 100755
--- a/tt_metal/tt-llk/tests/setup_external_testing_env.sh
+++ b/tt_metal/tt-llk/tests/setup_external_testing_env.sh
@@ -31,13 +31,34 @@ check_deps() {
 # Check for supported Python version
 check_python_version() {
     PYTHON_VERSION=$(python3 --version 2>&1 | cut -d' ' -f2)
-    if [[ "$PYTHON_VERSION" != "3.10"* ]]; then
-        echo "Error: Only Python 3.10 is supported. Detected: $PYTHON_VERSION" >&2
+    PYTHON_MAJOR=$(printf '%s' "$PYTHON_VERSION" | cut -d. -f1)
+    PYTHON_MINOR=$(printf '%s' "$PYTHON_VERSION" | cut -d. -f2)
+    if ! [[ "$PYTHON_MAJOR" =~ ^[0-9]+$ && "$PYTHON_MINOR" =~ ^[0-9]+$ ]]; then
+        echo "Error: Unable to parse Python version: $PYTHON_VERSION" >&2
+        exit 1
+    fi
+    if (( PYTHON_MAJOR < 3 || (PYTHON_MAJOR == 3 && PYTHON_MINOR < 10) )); then
+        echo "Error: Python 3.10 or newer is required. Detected: $PYTHON_VERSION" >&2
         exit 1
     fi
     echo "Supported Python version detected: $PYTHON_VERSION"
 }
 
+install_system_packages() {
+    echo "Updating and installing system packages..."
+    if command -v apt-get >/dev/null 2>&1; then
+        sudo apt-get update
+        sudo apt-get install -y curl cmake build-essential libyaml-cpp-dev libhwloc-dev libzmq3-dev git-lfs xxd wget
+    elif command -v dnf >/dev/null 2>&1; then
+        sudo dnf install -y curl cmake gcc-c++ make yaml-cpp-devel hwloc-devel zeromq-devel git-lfs vim-common wget
+    elif command -v yum >/dev/null 2>&1; then
+        sudo yum install -y curl cmake gcc-c++ make yaml-cpp-devel hwloc-devel zeromq-devel git-lfs vim-common wget
+    else
+        echo "Error: No supported package manager found (apt-get/dnf/yum)." >&2
+        exit 1
+    fi
+}
+
 # --- Main Script ---
 
 # Parse arguments
@@ -76,9 +97,7 @@ if [[ "$REUSE" == false || ! -d "$VENV_DIR" ]]; then
     echo "Performing full setup..."
 
     # Install system packages
-    echo "Updating and installing system packages..."
-    sudo apt-get update
-    sudo apt-get install -y curl cmake software-properties-common build-essential libyaml-cpp-dev libhwloc-dev libzmq3-dev git-lfs xxd wget
+    install_system_packages
 
     # Create virtual environment
     echo "Creating Python virtual environment..."
@@ -94,7 +113,44 @@ if [[ "$REUSE" == false || ! -d "$VENV_DIR" ]]; then
 
     # Install all Python dependencies
     echo "Installing Python dependencies..."
-    uv pip install -q --index-strategy unsafe-best-match --no-cache-dir -r requirements.txt
+    if uv pip install --index-strategy unsafe-best-match --no-cache-dir -r requirements.txt; then
+        echo "All dependencies installed successfully via uv pip"
+    else
+        echo "Standard pip install failed. Attempting source-build fallback for tt-umd..."
+        tt_umd_req=$(sed -nE '/^\s*tt-umd\s*(==|[#[:space:]]|$)/p' requirements.txt | head -n1)
+        tt_umd_ver=$(sed -nE 's/^\s*tt-umd\s*==\s*([^#[:space:]]+).*/\1/p' requirements.txt | head -n1)
+        tt_exalens_req=$(sed -nE '/^\s*tt-exalens\s*(==|[#[:space:]]|$)/p' requirements.txt | head -n1)
+        tt_exalens_ver=$(sed -nE 's/^\s*tt-exalens\s*==\s*([^#[:space:]]+).*/\1/p' requirements.txt | head -n1)
+        if [[ -n "$tt_umd_req" && -z "$tt_umd_ver" ]]; then
+            echo "ERROR: tt-umd must be exact-pinned for source-build fallback: $tt_umd_req" >&2
+            exit 1
+        fi
+        if [[ -n "$tt_exalens_req" && -z "$tt_exalens_ver" ]]; then
+            echo "ERROR: tt-exalens must be exact-pinned for fallback reinstall: $tt_exalens_req" >&2
+            exit 1
+        fi
+        uv pip install --index-strategy unsafe-best-match --no-cache-dir -r <(sed -E '/^\s*(tt-umd|tt-exalens)\s*(==|[#[:space:]]|$)/d' requirements.txt)
+
+        if [[ -n "$tt_umd_ver" ]]; then
+            echo "Extracted tt-umd version pin: $tt_umd_ver"
+            tag_name="v$tt_umd_ver"
+            if [[ "$tt_umd_ver" =~ \.dev ]]; then
+                tag_name="v$(echo "$tt_umd_ver" | sed 's/\.dev/-dev./')"
+            fi
+            echo "Attempting to build tt-umd from source tag: $tag_name"
+            if ! uv pip install --index-strategy unsafe-best-match --no-cache-dir "git+https://github.com/tenstorrent/tt-umd.git@$tag_name"; then
+                echo "Tag $tag_name installation failed. Attempting fallback to v$tt_umd_ver..."
+                if ! uv pip install --index-strategy unsafe-best-match --no-cache-dir "git+https://github.com/tenstorrent/tt-umd.git@v$tt_umd_ver"; then
+                    echo "ERROR: Failed to install tt-umd from source tags ($tag_name or v$tt_umd_ver)." >&2
+                    exit 1
+                fi
+            fi
+        fi
+
+        if [[ -n "$tt_exalens_ver" ]]; then
+            uv pip install --index-strategy unsafe-best-match --no-cache-dir "tt-exalens==$tt_exalens_ver"
+        fi
+    fi
 
     # Download and extract SFPI release
     ./setup_testing_env.sh

-- 
2.53.0.windows.2
