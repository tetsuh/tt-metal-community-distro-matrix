From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Tetsuya Hayashi <tetsu.h@gmail.com>
Date: Mon, 4 May 2026 07:01:47 +0900
Subject: [PATCH] install_dependencies: run install_llvm before install_sfpi

install_sfpi may install the sfpi .deb with 'dpkg --force-depends'
on distros (e.g. Debian 12) where the package's libstdc++6
dependency cannot be satisfied via apt.  This leaves the apt
database in a 'broken packages' state, which causes the next
apt-based install (currently the clang-N install inside llvm.sh) to
fail with messages like:

  E: Unable to correct problems, you have held broken packages.
  Try 'apt --fix-broken install' with no packages [...]

Reorder the calls so install_llvm runs while the apt resolver is
still clean; install_sfpi's force-depends state then no longer
blocks anything else.  The reordering is harmless on distros where
install_sfpi goes through apt cleanly (Ubuntu, Debian 13).

Upstream-Status: Pending
Distro-Scope: ubuntu, debian-12, debian-13 (general improvement)
---
 install_dependencies.sh | 9 ++++++++-
 1 file changed, 8 insertions(+), 1 deletion(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index 654b9df5..c6ae2735 100755
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -529,11 +529,18 @@ install() {
     install_packages
 
     # Install specialized components (SFPI and MPI/ULFM come from container layers when --docker)
+    #
+    # NOTE: install_llvm runs BEFORE install_sfpi. install_sfpi may use
+    # 'dpkg --force-depends' on Debian, which leaves the apt database in a
+    # 'broken packages' state. A subsequent apt-get install (such as the one
+    # inside llvm.sh) then refuses to proceed until --fix-broken is run.
+    # Installing LLVM first keeps the apt resolver clean. Order does not
+    # matter on distros where install_sfpi goes through apt cleanly.
+    install_llvm
     if [ "$docker" -ne 1 ]; then
         install_sfpi
         install_mpi_ulfm
     fi
-    install_llvm
 
     # Set gcc/g++ and clang/clang++ defaults via update-alternatives (docker builds only)
     if [ "$docker" -eq 1 ]; then
-- 
