From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ttossj1 <ttossj1@example.com>
Date: Mon, 4 May 2026 07:01:47 +0900
Subject: [PATCH] install_dependencies: run install_llvm before install_sfpi

install_sfpi may install the sfpi .deb with 'dpkg --force-depends'
on distros (e.g. Debian 12) where the package's libstdc++6
dependency cannot be satisfied via apt.  This leaves the apt
database in a 'broken packages' state, which causes the next
apt-based install (currently the clang-N install inside llvm.sh) to
fail with messages like:

  E: Unable to correct problems, you have held broken packages.
  Try 'apt --fix-broken install' with no packages [...]

Reorder the calls so install_llvm runs while the apt resolver is
still clean; install_sfpi's force-depends state then no longer
blocks anything else.  This is a no-op on distros where install_sfpi
goes through apt cleanly (Ubuntu, Debian 13).

Upstream-Status: Pending
Distro-Scope: ubuntu, debian-12, debian-13 (general improvement)
---
 install_dependencies.sh | 10 ++++++++--
 1 file changed, 8 insertions(+), 2 deletions(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index fd11bbc..678d26b 100755
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -473,9 +473,15 @@ install() {
     # Install core packages
     install_packages
 
-    # Install specialized components
-    install_sfpi
+    # Install specialized components.
+    # NOTE: install_llvm must run before install_sfpi.  install_sfpi
+    # may use 'dpkg --force-depends' on Debian, which leaves the apt
+    # database in a 'broken packages' state.  Subsequent apt-get
+    # install runs (such as the one inside llvm.sh) then refuse to
+    # proceed until --fix-broken is run.  Installing LLVM first keeps
+    # the apt resolver clean.
     install_llvm
+    install_sfpi
     install_mpi_ulfm
 
     # Configure system (hugepages, etc.) - only for baremetal if requested (not docker)
-- 
