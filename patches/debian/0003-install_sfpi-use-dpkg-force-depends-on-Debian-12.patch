From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: ttossj1 <ttossj1@example.com>
Date: Mon, 4 May 2026 07:01:18 +0900
Subject: [PATCH] install_sfpi: use dpkg --force-depends on Debian 12

The upstream sfpi .deb declares Depends: libstdc++6 (>= 12.3.0).
Debian 12 (bookworm) ships libstdc++6 12.2.0 in both main and
backports, and gcc-13 is not available in backports either, so apt
refuses the install.

The sfpi binaries link only against widely-available libstdc++
symbols, so relax the install to dpkg -i --force-depends only when
running on Debian 12.  Other distros keep the existing apt-get
install --allow-downgrades path.

Upstream-Status: Pending
Distro-Scope: debian-12
---
 install_dependencies.sh | 10 +++++++++-
 1 file changed, 9 insertions(+), 1 deletion(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index e0c4cf8..fd11bbc 100755
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -372,7 +372,15 @@ install_sfpi() {
     # we must select exactly this version
     case "$sfpi_pkg" in
 	deb)
-	    apt-get install -y --allow-downgrades $TEMP_DIR/$sfpi_filename
+	    # On Debian 12 (bookworm) the upstream sfpi package declares
+	    # Depends: libstdc++6 (>= 12.3.0) but bookworm ships 12.2.0 in
+	    # both main and backports.  The sfpi binaries only require widely
+	    # available libstdc++ symbols, so use dpkg --force-depends there.
+	    if [ "${ID:-}" = "debian" ] && [ "${VERSION_ID:-}" = "12" ]; then
+		dpkg -i --force-depends "$TEMP_DIR/$sfpi_filename"
+	    else
+		apt-get install -y --allow-downgrades "$TEMP_DIR/$sfpi_filename"
+	    fi
 	    ;;
 	rpm)
 	    rpm --upgrade --force $TEMP_DIR/$sfpi_filename
-- 
