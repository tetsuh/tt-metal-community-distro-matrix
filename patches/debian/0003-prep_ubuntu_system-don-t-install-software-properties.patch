From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Tetsuya Hayashi <tetsu.h@gmail.com>
Date: Mon, 4 May 2026 10:00:48 +0900
Subject: [PATCH] prep_ubuntu_system: don't install software-properties-common
 on Debian 13

software-properties-common provides /usr/bin/add-apt-repository.  On
Debian 13 (trixie) the source package was dropped from the archive
because Debian does not use PPAs and add-apt-repository has no useful
purpose there; installing it unconditionally fails with:

  E: Unable to locate package software-properties-common

It is tempting to drop the package on every Debian release, but on
Debian 12 (bookworm) the bundled apt.llvm.org installer (llvm.sh) still
hard-requires add-apt-repository -- it only stops probing for it on
"new" Debian releases (trixie and forky).  So the patch keeps
software-properties-common in the install set everywhere except on
Debian 13+, where it is both unavailable and unneeded.

Upstream-Status: Pending
Distro-Scope: debian-13
---
 install_dependencies.sh | 16 +++++++++++++++-
 1 file changed, 15 insertions(+), 1 deletion(-)

diff --git a/install_dependencies.sh b/install_dependencies.sh
index 9d860a0..56af46d 100644
--- a/install_dependencies.sh
+++ b/install_dependencies.sh
@@ -272,10 +272,24 @@ prep_ubuntu_system() {
     echo "[INFO] Preparing Ubuntu/Debian system..."
     # Update package lists and install basic tools
     apt-get update
-    apt-get install -y --no-install-recommends ca-certificates gpg lsb-release wget software-properties-common gnupg jq
+    # software-properties-common provides 'add-apt-repository'.  It is
+    # not packaged on Debian 13 (trixie) -- the source package was
+    # dropped from the Debian archive because Debian does not use
+    # PPAs.  On Debian 13 we therefore drop the package; on Ubuntu
+    # and on Debian 12 (bookworm) the package still exists and is
+    # required by llvm.sh below, which probes for add-apt-repository
+    # unless it is running on a "new" Debian (trixie+).
+    base_pkgs="ca-certificates gpg lsb-release wget software-properties-common gnupg jq"
+    if [ "${ID:-}" = "debian" ] && { [ "${VERSION_CODENAME:-}" = "trixie" ] || [ "${VERSION_CODENAME:-}" = "forky" ] || [ "${VERSION_CODENAME:-}" = "unstable" ]; }; then
+	base_pkgs="ca-certificates gpg lsb-release wget gnupg jq"
+    fi
+    apt-get install -y --no-install-recommends $base_pkgs
 
     # Add LLVM repository for Clang 17
     local llvm_keyring="/usr/share/keyrings/llvm-snapshot.gpg"
+    if [ "${ID:-}" = "debian" ] && { [ "${VERSION_CODENAME:-}" = "trixie" ] || [ "${VERSION_CODENAME:-}" = "forky" ] || [ "${VERSION_CODENAME:-}" = "unstable" ]; }; then
+	llvm_keyring="/etc/apt/trusted.gpg.d/apt.llvm.org.asc"
+    fi
     local llvm_keyring_tmp
     llvm_keyring_tmp="$(mktemp "${llvm_keyring}.XXXXXX")"
     ( set -o pipefail; wget -O - https://apt.llvm.org/llvm-snapshot.gpg.key | gpg --dearmor --batch --yes --no-tty -o "$llvm_keyring_tmp" )
-- 
